{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Only (with sound)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\run_with_sound.ps1",
        "-Compile",
        "g++ \"${file}\" -o \"${fileBasenameNoExtension}.exe\""
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Build and Run (with sound)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\run_with_sound.ps1",
        "-Compile",
        "g++ \"${file}\" -o \"${fileBasenameNoExtension}.exe\"",
        "-Run",
        ".\\${fileBasenameNoExtension}.exe"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$gcc"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
